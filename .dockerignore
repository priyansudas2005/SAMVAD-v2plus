# Git
.git
.gitignore
.gitattributes

# Docker (don't send Dockerfiles into the build context recursively)
.dockerignore

# Python bytecode & virtual environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
backend/venv/
backend/.venv/
.pytest_cache/

# Data directories (mounted as named volumes at runtime)
backend/data/database/
backend/data/recordings/
logs/

# Models (downloaded at runtime, persisted in volumes)
models/

# Non-runtime directories
docs/
site/
plan/
scratch/
deployment/
.forgejo/
.github/
.claude/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# Logs and misc
*.log
*.md
!backend/requirements.txt
LICENSE
CLA.md

# Frontend build artifacts (only needed in frontend Dockerfile)
frontend/node_modules/
frontend/dist/

# Testing (included in backend image for CI, excluded from frontend)
backend/tests/__pycache__/
